{{!< default}}

{{#post}}
<article class="donate-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section --}}
    <header class="donate-hero" style="background-image: url('{{feature_image}}');">
        <div class="donate-hero-overlay"></div>
        <div class="container donate-hero-content reveal">
            <h1 class="donate-title">{{title}}</h1>
            <p class="donate-subtitle">{{custom_excerpt}}</p>
        </div>
        
        {{!-- Dynamic Wave Shape Divider --}}
        <div class="section-divider">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" preserveAspectRatio="none">
                <path fill="#ffffff" fill-opacity="1" d="M0,160L48,176.000C96,192,192,224,288,213.3C384,203,480,149,576,149.3C672,149,768,203,864,213.3C960,224,1056,192,1152,170.7C1248,149,1344,139,1392,133.3L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
            </svg>
        </div>
    </header>

    <div class="container donate-container">
        {{!-- Main Donation Content --}}
        <div class="donate-grid">
            
            {{!-- Left Side: Foundation Message --}}
            <div class="donate-message reveal reveal-left">
                {{#get "posts" filter="tag:hash-donate-message" limit="1"}}
                {{#foreach posts}}
                <div class="message-card">
                    {{#if primary_tag}}<span class="message-label">{{primary_tag.name}}</span>{{/if}}
                    <h2 class="message-title">{{title}}</h2>
                    <p class="message-text">
                        {{custom_excerpt}}
                    </p>
                    
                    <ul class="impact-list">
                        {{#get "posts" filter="tag:hash-donate-impact" order="published_at asc" limit="5"}}
                        {{#foreach posts}}
                        <li>
                            <div class="impact-icon">
                                {{#if feature_image}}
                                    <img src="{{feature_image}}" alt="{{title}}" style="width: 24px; height: 24px; object-fit: contain; filter: invert(1);">
                                {{else}}
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3.33 3 6.67 3 10 0v-5"></path></svg>
                                {{/if}}
                            </div>
                            <div class="impact-content">
                                <strong>{{title}}</strong>
                                <span>{{custom_excerpt}}</span>
                            </div>
                        </li>
                        {{/foreach}}
                        {{/get}}
                    </ul>

                    <div class="trust-badge-wrap gh-content">
                        {{content}}
                    </div>
                </div>
                {{/foreach}}
                {{/get}}
            </div>

            {{!-- Right Side: Bank Details Box --}}
            <div class="donate-box-wrap reveal reveal-right">
                <div class="donate-box-glass bank-details-glass">
                    <div class="donate-box-header">
                        <h3>Bank Transfer Details</h3>
                    </div>
                    
                    <div class="bank-details-premium">
                        {{#get "posts" filter="tag:hash-donate-bank" limit="1"}}
                        {{#foreach posts}}
                            <div class="bank-dynamic-content">
                                {{content}}
                            </div>
                        {{else}}
                            <div class="fallback-bank" style="padding: 30px; text-align: center; color: #888;">
                                <p><em>Create a Post tagged with <strong>#hash-donate-bank</strong> to show your banking details here. Use a bulleted list for best results!</em></p>
                            </div>
                        {{/foreach}}
                        {{/get}}
                    </div>
                </div>
            </div>
        </div>

        {{!-- Secure Information Section --}}
        <section class="secure-info reveal">
            <div class="secure-info-content">
                {{#get "posts" filter="tag:hash-donate-secure" order="published_at asc" limit="3"}}
                {{#foreach posts}}
                <div class="secure-item">
                    <div class="secure-icon">
                        {{#if feature_image}}<img src="{{feature_image}}" alt="{{title}}" style="width:24px; filter: grayscale(1);">{{else}}
                            {{#has number="1"}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>{{/has}}
                            {{#has number="2"}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>{{/has}}
                            {{^has number="1,2"}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>{{/has}}
                        {{/if}}
                    </div>
                    <div class="secure-text">
                        <h4>{{title}}</h4>
                        <p>{{custom_excerpt}}</p>
                    </div>
                </div>
                {{else}}
                <!-- BEAUTIFUL FALLBACK TO FILL WHITESPACE WITH ANIMATION -->
                <div class="secure-item reveal">
                    <div class="secure-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    </div>
                    <div class="secure-text">
                        <h4>100% Secure</h4>
                        <p>Your transactions are securely processed directly into our official Trust account.</p>
                    </div>
                </div>
                <div class="secure-item reveal" style="animation-delay: 0.2s;">
                    <div class="secure-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    </div>
                    <div class="secure-text">
                        <h4>Tax Exempt (80G)</h4>
                        <p>All contributions are fully eligible for tax deductions under the 80G certificate.</p>
                    </div>
                </div>
                <div class="secure-item reveal" style="animation-delay: 0.4s;">
                    <div class="secure-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                    <div class="secure-text">
                        <h4>Direct Impact</h4>
                        <p>100% of your generated funds go directly to grassroots community projects.</p>
                    </div>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </section>
    </div>

</article>
{{/post}}
