{{!< default}}

{{#post}}
<article class="our-work-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section --}}
    <header class="work-hero-full" {{#if feature_image}}style="background-image: url('{{feature_image}}'); background-size: cover; background-position: center;"{{/if}}>
        <div class="container work-hero-content reveal">
            {{#if primary_tag}}<span class="hero-label">{{primary_tag.name}}</span>{{/if}}
            <h1 class="work-title">{{title}}</h1>
            <p class="work-subtitle">{{custom_excerpt}}</p>
        </div>
    </header>

    {{!-- Alternating Focus Area Sections --}}
    <section class="focus-areas-alternating">
        {{#get "posts" filter="tag:hash-work-focus" order="published_at asc"}}
        {{#foreach posts}}
        <div class="work-project-block {{#if @odd}}block-reverse{{/if}} reveal">
            <div class="project-image-side">
                {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}" class="project-img-parallax">
                {{/if}}
            </div>
            <div class="project-content-side">
                {{#if primary_tag}}<div class="project-badge">{{primary_tag.name}}</div>{{/if}}
                <h2>{{title}}</h2>
                <p>{{custom_excerpt}}</p>
                <div class="project-stats-mini gh-content">
                    {{content}}
                </div>
            </div>
        </div>
        {{/foreach}}
        {{/get}}
    </section>

    {{!-- Approach Cards --}}
    <section class="approach-section reveal">
        <div class="container text-center">
            {{#get "posts" filter="tag:hash-work-approach-title" limit="1"}}
                {{#foreach posts}}
                    <h2 class="section-title">{{title}}</h2>
                {{/foreach}}
            {{else}}
                <h2 class="section-title">Our Unique Approach</h2>
            {{/get}}
            
            <div class="approach-grid">
                {{#get "posts" filter="tag:hash-work-approach" order="published_at asc" limit="3"}}
                {{#foreach posts}}
                <div class="approach-card-tilted {{#has number="2"}}card-primary{{/has}}">
                    <div class="approach-icon">
                        {{#if feature_image}}
                            <img src="{{feature_image}}" alt="{{title}}" style="width: 40px; height: 40px; object-fit: contain;">
                        {{else}}
                            {{#has number="1"}}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>{{/has}}
                            {{#has number="2"}}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>{{/has}}
                            {{^has number="1,2"}}<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>{{/has}}
                        {{/if}}
                    </div>
                    <h4>{{title}}</h4>
                    <p>{{custom_excerpt}}</p>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- Original Content (Accessible) --}}
    <section class="original-content-section reveal">
        <div class="container post-content-body">
            {{content}}
        </div>
    </section>

</article>
{{/post}}

