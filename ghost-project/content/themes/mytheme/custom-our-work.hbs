{{!< default}}

{{#post}}
<article class="our-work-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section --}}
    <header class="work-hero-full">
        <div class="container work-hero-content reveal">
            <span class="hero-label">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}What We Do{{/if}}</span>
            <h1 class="work-title">{{title}}</h1>
            <p class="work-subtitle">{{excerpt}}</p>
        </div>
    </header>

    {{!-- Alternating Focus Area Sections --}}
    <section class="focus-areas-alternating">
        {{#get "posts" filter="tag:hash-focus-area" order="published_at asc" limit="10"}}
            {{#foreach posts}}
            <div class="work-project-block {{#if @odd}}block-reverse{{/if}} reveal">
                <div class="project-image-side">
                    <img src="{{#if feature_image}}{{img_url feature_image}}{{else}}{{asset "images/impact-hero.jpg"}}{{/if}}" alt="{{title}}" class="project-img-parallax">
                </div>
                <div class="project-content-side">
                    <div class="project-badge">Focus Area 0{{@number}}</div>
                    <h2>{{title}}</h2>
                    <p>{{excerpt}}</p>
                    <div class="project-stats-mini">
                        {{content}}
                    </div>
                </div>
            </div>
            {{/foreach}}
        {{/get}}
    </section>

    {{!-- Approach Cards --}}
    <section class="approach-section reveal">
        <div class="container text-center">
            {{#get "pages" slug="our-work-approach-heading" limit="1"}}
                {{#foreach pages}}
                    <h2 class="section-title">{{title}}</h2>
                {{/foreach}}
            {{else}}
                <h2 class="section-title">Our Unique Approach</h2>
            {{/get}}
            
            <div class="approach-grid">
                {{#get "posts" filter="tag:hash-approach-card" order="published_at asc" limit="3"}}
                    {{#foreach posts}}
                    <div class="approach-card-tilted {{#if @odd}}card-primary{{/if}}">
                        {{#if custom_excerpt}}
                        <div class="approach-icon">{{{custom_excerpt}}}</div>
                        {{/if}}
                        <h4>{{title}}</h4>
                        <p>{{excerpt}}</p>
                    </div>
                    {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- Original Content (Hidden but accessible if needed) --}}
    <section class="original-content-section hidden">
        <div class="container post-content-body">
            {{content}}
        </div>
    </section>

</article>
{{/post}}
