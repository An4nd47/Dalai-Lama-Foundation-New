{{!< default}}

<section class="section">
    <h1>{{title}}</h1>
    <p><em>{{date}}</em></p>

    {{#if feature_image}}
        <img src="{{feature_image}}" style="width:100%; max-height:400px; object-fit:cover;">
    {{/if}}

    <div class="post-content">
        {{content}}
    </div>
</section>