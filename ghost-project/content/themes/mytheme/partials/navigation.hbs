{{#if isSecondary}}
    <div class="hero-cta">
        {{#foreach navigation}}
            <a href="{{url absolute="true"}}" class="btn {{#if @first}}btn-primary{{else}}btn-secondary{{/if}}">{{label}}</a>
        {{/foreach}}
    </div>
{{else}}
    <ul class="nav">
        {{#foreach navigation}}
            <li class="{{link_class for=(url) class=(concat "nav-" slug)}}">
                <a href="{{url absolute="true"}}">{{label}}</a>
            </li>
        {{/foreach}}
    </ul>
{{/if}}
