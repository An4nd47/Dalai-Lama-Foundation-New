<section class="programs-section">
    <div class="container">
        <h2 class="section-title">Programs & Initiatives</h2>
        
        {{!-- Get posts tagged with #program --}}
        {{#get "posts" filter="tag:hash-program" limit="3" include="tags,authors"}}
        <div class="programs-grid">
            {{#foreach posts}}
                <article class="program-card">
                    <a href="{{url}}" class="program-card-link">
                        <div class="program-card-image-wrap">
                            {{#if feature_image}}
                                <img src="{{img_url feature_image size="m"}}" alt="{{title}}" class="program-card-image">
                            {{else}}
                                <div class="program-card-placeholder"></div>
                            {{/if}}
                        </div>
                        <div class="program-card-content">
                            <h3 class="program-card-title">{{title}}</h3>
                            <p class="program-card-excerpt">{{excerpt words="15"}}...</p>
                            <span class="program-card-more">Learn More <span class="arrow">&rarr;</span></span>
                        </div>
                    </a>
                </article>
            {{else}}
                <div class="placeholder-content">
                    <p>Tag posts with <code>#program</code> to showcase initiatives here.</p>
                </div>
            {{/foreach}}
        </div>
        {{/get}}
    </div>
</section>
