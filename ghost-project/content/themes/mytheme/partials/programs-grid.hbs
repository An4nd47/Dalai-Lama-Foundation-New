<section class="programs-section">
    <div class="container">
        <div class="stories-scroller-header">
            {{#get "pages" slug="section-programs" limit="1"}}
                {{#foreach pages}}
                    <h2 class="section-title reveal">{{title}}</h2>
                {{/foreach}}
            {{/get}}
            <div class="scroller-controls">
                <button class="scroller-btn programs-prev" aria-label="Previous">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                </button>
                <button class="scroller-btn programs-next" aria-label="Next">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
            </div>
        </div>

        {{#get "posts" filter="tag:hash-program" limit="6" include="tags,authors"}}
        <div class="programs-scroller-outer">
            <div class="programs-scroller-inner">
                {{#foreach posts}}
                    <article class="program-card-premium program-scroller-item reveal">
                        <a href="{{url}}" class="program-card-link">
                            <div class="program-card-image-wrap">
                                {{#if feature_image}}
                                    <img src="{{img_url feature_image size="m"}}" alt="{{title}}" class="program-card-image">
                                {{else}}
                                    <div class="program-card-placeholder">
                                        <svg class="placeholder-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                                    </div>
                                {{/if}}
                                <div class="program-card-tag">{{#primary_tag}}{{name}}{{/primary_tag}}</div>
                            </div>
                            <div class="program-card-body">
                                <h3 class="program-card-title">{{title}}</h3>
                                <p class="program-card-excerpt">{{excerpt words="14"}}...</p>
                                <div class="program-card-footer">
                                    <span class="read-more-text">{{t "Explore"}} <span class="arrow">&rarr;</span></span>
                                </div>
                            </div>
                        </a>
                    </article>
                {{/foreach}}
            </div>
        </div>
        {{/get}}
    </div>
</section>
