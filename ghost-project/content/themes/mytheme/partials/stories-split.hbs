<section class="stories-split-section">
    <div class="container">
        <div class="stories-scroller-header">
            {{#get "pages" slug="section-highlights" limit="1"}}
                {{#foreach pages}}
                    <h2 class="section-title">{{title}}</h2>
                {{/foreach}}
            {{else}}
                <h2 class="section-title">{{t "Highlights"}}</h2>
            {{/get}}
            <div class="scroller-controls">
                <button class="scroller-btn prev" aria-label="Previous">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                </button>
                <button class="scroller-btn next" aria-label="Next">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
            </div>
        </div>
        
        {{#get "posts" limit="6" filter="tag:-hash-site-stat+tag:-hash-program" include="tags,authors"}}
        <div class="stories-scroller-outer">
            <div class="stories-scroller-inner">
                {{#foreach posts}}
                <div class="story-card-inner" {{#if feature_image}}style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('{{img_url feature_image size="m"}}')"{{/if}}>
                    <div class="story-card-content">
                        <span class="story-meta-light">{{tags limit="1"}}</span>
                        <h3 class="story-card-title">{{title}}</h3>
                        <p class="story-card-text">{{excerpt words="10"}}</p>
                        <a href="{{url}}" class="btn btn-primary btn-rounded btn-small">{{t "Read More"}}</a>
                    </div>
                </div>
                {{/foreach}}
            </div>
        </div>
        {{/get}}

        {{#get "pages" slug="partner-cta" limit="1"}}
            {{#foreach pages}}
                <div class="stories-featured-below">
                    <div class="featured-card-inner" {{#if feature_image}}style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('{{img_url feature_image size="m"}}')"{{/if}}>
                        <div class="featured-card-content">
                            <h2 class="featured-card-title">{{title}}</h2>
                            <p class="featured-card-text">{{excerpt words="20"}}</p>
                            <a href="{{url}}" class="btn btn-primary">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{t "Partner With Us"}}{{/if}}</a>
                        </div>
                    </div>
                </div>
            {{else}}
                <div class="stories-featured-below">
                    <div class="featured-card-inner" {{#if @site.cover_image}}style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('{{@site.cover_image}}')"{{/if}}>
                        <div class="featured-card-content">
                            <h2 class="featured-card-title">{{@site.title}} {{t "Partnerships"}}</h2>
                            <p class="featured-card-text">{{@site.description}}</p>
                            <a href="{{@site.url}}" class="btn btn-primary">{{t "Partner With Us"}}</a>
                        </div>
                    </div>
                </div>
            {{/foreach}}
        {{/get}}
    </div>
</section>
