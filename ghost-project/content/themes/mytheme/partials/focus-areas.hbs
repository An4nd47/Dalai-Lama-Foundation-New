<section class="focus-areas-section">
    <div class="container">
        <h2 class="section-title">Our Focus Areas</h2>
        
        {{#get "tags" filter="visibility:public" limit="4" include="count.posts"}}
        <div class="focus-areas-grid">
            {{#foreach tags}}
            <a href="{{url}}" class="focus-card">
                <div class="focus-icon-wrap">
                    {{#if feature_image}}
                        <img src="{{img_url feature_image size="s"}}" alt="{{name}}" class="focus-icon">
                    {{else}}
                        <div class="focus-icon-placeholder"></div>
                    {{/if}}
                </div>
                <h3 class="focus-title">{{name}}</h3>
                {{#if description}}
                    <p class="focus-description">{{description}}</p>
                {{/if}}
            </a>
            {{else}}
                <div class="placeholder-content">
                    <p>Create tags in Ghost Admin to see focus areas here.</p>
                </div>
            {{/foreach}}
        </div>
        {{/get}}
    </div>
</section>
