<section class="focus-areas-section">
    <div class="container">
        <h2 class="section-title">Our Focus Areas</h2>
        
        {{#get "tags" filter="visibility:public" limit="3" include="count.posts"}}
        <div class="focus-areas-grid">
            {{#foreach tags}}
            <div class="focus-card-dark" {{#if feature_image}}style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7)), url('{{img_url feature_image size="m"}}')"{{/if}}>
                <h3 class="focus-title-light">{{name}}</h3>
                {{#if description}}
                    <p class="focus-description-light">{{description}}</p>
                {{/if}}
                <a href="{{url}}" class="btn btn-primary btn-rounded">LEARN MORE</a>
            </div>
            {{else}}
                <div class="placeholder-content">
                    <p>Create at least one public tag in Ghost Admin to see focus areas here.</p>
                </div>
            {{/foreach}}
        </div>
        {{/get}}
    </div>
</section>
