<footer class="site-footer" role="contentinfo">
    <div class="container footer-grid">
        <div class="footer-col col-brand">
            <a href="{{@site.url}}" class="footer-logo-link">
                {{#if @site.logo}}
                    <div class="footer-logo-wrap">
                        <img class="footer-logo" src="{{@site.logo}}" alt="{{@site.title}}" />
                    </div>
                {{else}}
                    <span class="footer-title gold-text">{{@site.title}}</span>
                {{/if}}
            </a>
            {{#if @site.description}}
                <p class="footer-tagline">{{@site.description}}</p>
            {{/if}}
            <div class="footer-socials">
                {{#if @site.facebook}}
                    <a href="{{facebook_url @site.facebook}}" class="social-link" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                    </a>
                {{/if}}
                {{#if @site.twitter}}
                    <a href="{{twitter_url @site.twitter}}" class="social-link" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
                    </a>
                {{/if}}
            </div>
        </div>

        <div class="footer-col">
            <h4 class="footer-col-title">Navigation</h4>
            {{navigation}}
        </div>

        <div class="footer-col">
            <h4 class="footer-col-title">Resources</h4>
            {{navigation type="secondary"}}
        </div>

        <div class="footer-col col-contact">
            <h4 class="footer-col-title">Stay Updated</h4>
            <p>Join our newsletter for the latest impact stories and updates.</p>
            <a href="#/portal" class="btn btn-primary btn-rounded btn-small">Subscribe Now</a>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container">
            <div class="footer-bottom-inner">
                <p class="copyright">&copy; {{date format="YYYY"}} {{@site.title}}. All Rights Reserved.</p>
                <div class="footer-legal">
                    <a href="https://ghost.org" target="_blank" rel="noopener">Powered by Ghost</a>
                </div>
            </div>
        </div>
    </div>
</footer>
