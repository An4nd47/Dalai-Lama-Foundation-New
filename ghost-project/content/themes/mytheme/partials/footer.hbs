<footer class="site-footer" role="contentinfo">
    <div class="container footer-grid">
        <div class="footer-col col-brand">
            <a href="{{@site.url}}" class="footer-logo-link">
                {{#if @site.logo}}
                    <div class="footer-logo-wrap">
                        <img class="footer-logo" src="{{@site.logo}}" alt="{{@site.title}}" />
                    </div>
                {{else}}
                    <span class="footer-title gold-text">{{@site.title}}</span>
                {{/if}}
            </a>
            {{#if @site.description}}
                <p class="footer-tagline">{{@site.description}}</p>
            {{/if}}
            <div class="footer-socials">
                {{#get "pages" slug="footer-social-links" limit="1"}}
                    {{#foreach pages}}
                        <div class="footer-social-page-content">
                            {{content}}
                        </div>
                    {{else}}
                        <div class="footer-social-placeholder">
                            <p class="small opacity-60">Create a page with slug 'footer-social-links' to manage social icons.</p>
                        </div>
                    {{/foreach}}
                {{/get}}
            </div>
        </div>

        <div class="footer-col">
            <h4 class="footer-col-title">Navigation</h4>
            {{navigation}}
        </div>

        <div class="footer-col col-contact">
            <h4 class="footer-col-title">Contact Us</h4>
            {{#get "pages" slug="footer-contact-info" limit="1"}}
                {{#foreach pages}}
                    <div class="footer-contact-content">
                        {{content}}
                    </div>
                {{else}}
                    <div class="footer-contact-content">
                        <p>Plot No. 50, M.K. Nagar, Nandurbar</p>
                        <p>foundationdalailama@gmail.com</p>
                        <p>+91 7841918383</p>
                    </div>
                {{/foreach}}
            {{/get}}
        </div>

        <div class="footer-col col-subscribe">
            <h4 class="footer-col-title">Stay Updated</h4>
            <p>Join our newsletter for the latest impact stories and updates.</p>
            <a href="#/portal" class="btn btn-primary btn-rounded btn-small">Subscribe Now</a>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container">
            <div class="footer-bottom-inner">
                <p class="copyright">&copy; {{date format="YYYY"}} {{@site.title}}. All Rights Reserved.</p>
                <div class="footer-legal">
                    <a href="https://ghost.org" target="_blank" rel="noopener">Powered by Ghost</a>
                </div>
            </div>
        </div>
    </div>
</footer>
