{{!< default}}

{{!-- Hero Section — uses site cover image and description from Ghost Admin --}}
<section class="hero-section" {{#if @site.cover_image}}style="background-image: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.55)), url('{{@site.cover_image}}')"{{/if}}>
    <div class="hero-content">
        <h1 class="hero-heading">{{@site.description}}</h1>
        <div class="hero-cta">
            {{#get "pages" filter="tag:partner" limit="1"}}
                {{#foreach pages}}
                    <a href="{{url}}" class="btn btn-primary">Partner With Us</a>
                {{/foreach}}
            {{/get}}
            {{#get "pages" filter="tag:explore" limit="1"}}
                {{#foreach pages}}
                    <a href="{{url}}" class="btn btn-secondary">Explore Our Work</a>
                {{/foreach}}
            {{/get}}
        </div>
    </div>
</section>

{{!-- Featured Posts Section --}}
{{#get "posts" filter="featured:true" limit="4" include="tags,authors"}}
    {{#if posts}}
        <section class="featured-section">
            <div class="container">
                <h2 class="section-title">Featured</h2>
                <div class="featured-grid">
                    {{#foreach posts}}
                        {{> post-card}}
                    {{/foreach}}
                </div>
            </div>
        </section>
    {{/if}}
{{/get}}

{{!-- Recent Posts Section — main post loop --}}
<section class="posts-section">
    <div class="container">
        <h2 class="section-title">Recent Posts</h2>

        {{#if posts}}
            <div class="posts-grid">
                {{#foreach posts}}
                    {{> post-card}}
                {{/foreach}}
            </div>
        {{else}}
            <div class="no-posts">
                <p>No posts published yet. Content will appear here once posts are created in the Ghost Admin panel.</p>
            </div>
        {{/if}}
    </div>
</section>

{{!-- Pagination --}}
{{> pagination}}