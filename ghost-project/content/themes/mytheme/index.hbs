{{!< default}}

<section class="hero-section" {{#if @site.cover_image}}style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('{{@site.cover_image}}')"{{/if}}>
    <div class="hero-content">
        <h1 class="hero-heading">Empowering Tribal & Rural Communities Through Education, Nutrition & Livelihoods</h1>
        <div class="hero-cta">
            <a href="#partner" class="btn btn-primary">Partner With Us</a>
            <a href="#work" class="btn btn-secondary">Explore Our Work</a>
        </div>
    </div>
</section>

