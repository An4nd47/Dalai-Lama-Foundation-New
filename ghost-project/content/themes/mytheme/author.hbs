{{!< default}}

<header class="author-header">
    <div class="container author-header-inner">
        {{#if profile_image}}
            <img class="author-avatar-large" src="{{profile_image}}" alt="{{name}}" loading="lazy" />
        {{/if}}
        <div class="author-info">
            <h1 class="author-name">{{name}}</h1>
            {{#if bio}}
                <p class="author-bio">{{bio}}</p>
            {{/if}}
            {{#if location}}
                <span class="author-location">📍 {{location}}</span>
            {{/if}}
        </div>
    </div>
</header>

<section class="posts-section">
    <div class="container">
        {{#if posts}}
            <div class="posts-grid">
                {{#foreach posts}}
                    {{> post-card}}
                {{/foreach}}
            </div>
        {{else}}
            <div class="no-posts">
                <p>No posts by this author yet.</p>
            </div>
        {{/if}}
    </div>
</section>

{{> pagination}}
