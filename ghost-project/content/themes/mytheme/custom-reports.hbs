{{!< default}}

{{#post}}
<article class="reports-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section — Formal & Authoritative --}}
    <header class="report-hero">
        <div class="container report-hero-content reveal">
            <span class="report-label">Transparency & Accountability</span>
            <h1 class="report-title">{{title}}</h1>
            <p class="report-subtitle">Access our annual performance and financial audits to see how every resource is used for the mission of compassion.</p>
        </div>
    </header>

    <div class="container report-container">
        
        {{!-- Featured Latest Report (2023-24) --}}
        <section class="latest-report-section reveal">
            <div class="year-marker">Latest Report: 2023–24</div>
            <div class="report-card-premium featured-report">
                <div class="report-icon-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <div class="report-info">
                    <h3>Annual Report 2023–24</h3>
                    <p>Financial Statement and Operational Highlights for the Year ending March 2024.</p>
                    <div class="report-highlights-mini">
                        <div class="h-stat"><strong>Total Income:</strong> </div>
                        <div class="h-stat"><strong>Audit:</strong> Complete & Verified</div>
                    </div>
                </div>
                <div class="report-action">
                    <a href="#" class="btn-download-formal">Download PDF <span class="file-size">(1.2 MB)</span></a>
                </div>
            </div>
            <div class="report-card-premium featured-report">
                <div class="report-icon-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <div class="report-info">
                    <h3>Audit Report 2023–24</h3>
                    <p>Financial Statement and Operational Highlights for the Year ending March 2024.</p>
                </div>
                <div class="report-action">
                    <a href="#" class="btn-download-formal">Download PDF <span class="file-size">(1.2 MB)</span></a>
                </div>
            </div>
            
            <div class="year-highlights reveal">
                <h4>2023–24 Key Highlights:</h4>
                <ul class="formal-highlights">
                    <li>Successful execution of <strong>government-supported projects</strong> across 15 districts.</li>
                    <li>Continued focus on <strong>nutrition and community development</strong> programs for tribal regions.</li>
                    <li>Scaling of <strong>women empowerment</strong> initiatives with a focus on self-reliance and entrepreneurship.</li>
                </ul>
            </div>
        </section>

        {{!-- Historical Reports Archive (2022-23) --}}
        <section class="historical-reports-section reveal">
            <div class="year-marker">Archive: 2022–23</div>
            <div class="report-card-premium">
                <div class="report-icon-box small">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <div class="report-info">
                    <h3>Annual Report 2022–23</h3>
                    <p>Overview of community development and social impact through sustainable initiatives.</p>
                    <div class="report-highlights-mini">
                        <div class="h-stat"><strong>70,000+</strong> <span>Meals Served</span></div>
                        <div class="h-stat"><strong>Audit:</strong> Verified</div>
                    </div>
                </div>
                <div class="report-action">
                    <a href="#" class="btn-download-outline">Download report <span class="file-size">(1 MB)</span></a>
                </div>
            </div>
            <div class="report-card-premium">
                <div class="report-icon-box small">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <div class="report-info">
                    <h3>Audit Report 2022–23</h3>
                    <p>Overview of community development and social impact through sustainable initiatives.</p>
                </div>
                <div class="report-action">
                    <a href="#" class="btn-download-outline">Download report <span class="file-size">(1 MB)</span></a>
                </div>
            </div>

            <div class="year-highlights reveal">
                <h4>2022–23 Achievements:</h4>
                <p>The foundation continued its commitment through a range of community development and social impact initiatives.</p>
                <ul class="formal-highlights small">
                    <li>Conducted multiple <strong>health and awareness programs</strong> in rural and tribal Maharashtra.</li>
                    <li>Successfully implemented various <strong>CSR-driven activities</strong> in collaboration with corporate partners.</li>
                </ul>
            </div>
        </section>

        {{!-- Original Page Content (for reference/hidden) --}}
        <section class="original-content-section hidden">
            <div class="container post-content-body">
                {{content}}
            </div>
        </section>
    </div>

</article>
{{/post}}
