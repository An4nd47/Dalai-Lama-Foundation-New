{{!< default}}

{{#post}}
<article class="team-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section --}}
    <div class="team-hero">
        <div class="container team-hero-content reveal">
            <h1 class="team-title">{{title}}</h1>
            <p class="team-subtitle">{{excerpt}}</p>
        </div>
    </div>

    <div class="container team-container">
        
        {{!-- Leadership Spotlight --}}
        <section class="leadership-spotlight reveal">
            {{#get "pages" slug="leadership-spotlight" limit="1"}}
                {{#foreach pages}}
                <div class="spotlight-card">
                    <div class="leader-image">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image}}" alt="{{title}}" class="leader-img-glow">
                        {{/if}}
                    </div>
                    <div class="leader-bio">
                        <div class="bio-label">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Leadership{{/if}}</div>
                        <h2>{{title}}</h2>
                        <p class="bio-short">{{excerpt}}</p>
                        <div class="bio-extended">
                            {{content}}
                        </div>
                    </div>
                </div>
                {{/foreach}}
            {{/get}}
        </section>

        {{!-- Team Structure Grid --}}
        <section class="team-grid-section reveal">
            {{#get "pages" slug="team-structure-heading" limit="1"}}
                {{#foreach pages}}
                    <h2 class="section-title text-center">{{title}}</h2>
                {{/foreach}}
            {{else}}
                <h2 class="section-title text-center">Our Core Structure</h2>
            {{/get}}
            <div class="team-structure-grid">
                {{#get "posts" filter="tag:hash-team-structure" order="published_at asc" limit="8"}}
                    {{#foreach posts}}
                    <div class="team-member-card">
                        {{#if custom_excerpt}}
                        <div class="member-icon">{{{custom_excerpt}}}</div>
                        {{/if}}
                        <h4>{{title}}</h4>
                        <p>{{excerpt}}</p>
                    </div>
                    {{/foreach}}
                {{/get}}
            </div>
        </section>

        {{!-- Original Page Content --}}
        <section class="original-content-section reveal">
            <div class="post-content-body">
                {{content}}
            </div>
        </section>
    </div>

</article>
{{/post}}
