{{!< default}}

{{#post}}
<article class="partnerships-page-wrapper {{post_class}}">
    
    {{!-- Premium Parallax Hero --}}
    <header class="partners-parallax-hero">
        <div class="parallax-bg" style="background-image: url('{{feature_image}}');"></div>
        <div class="partners-hero-overlay"></div>
        <div class="container partners-hero-content reveal">
            {{#if primary_tag}}<span class="hero-label-gold">{{primary_tag.name}}</span>{{/if}}
            <h1 class="partners-title-large">{{title}}</h1>
            <p class="partners-subtitle-large">{{custom_excerpt}}</p>
        </div>
        <div class="hero-wave">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" preserveAspectRatio="none">
                <path fill="#ffffff" fill-opacity="1" d="M0,224L48,213.3C96,203,192,181,288,181.3C384,181,480,203,576,224C672,245,768,267,864,250.7C960,235,1056,181,1152,149.3C1248,117,1344,107,1392,101.3L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
            </svg>
        </div>
    </header>

    <div class="container partners-main">
        
        {{!-- Iconic Value Grid --}}
        <section class="partnership-values-section reveal">
            <div class="partners-value-grid">
                {{#get "posts" filter="tag:hash-partner-value" order="published_at asc" limit="3"}}
                {{#foreach posts}}
                <div class="value-card-premium {{#has number="2"}}card-active{{/has}}">
                    <div class="value-icon-box">
                        {{#if feature_image}}<img src="{{feature_image}}" alt="{{title}}" style="width: 48px; object-fit: contain;">{{else}}
                            {{#has number="1"}}<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>{{/has}}
                            {{#has number="2"}}<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>{{/has}}
                            {{#has number="3"}}<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>{{/has}}
                            {{^has number="1,2,3"}}<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>{{/has}}
                        {{/if}}
                    </div>
                    <div class="value-text-box">
                        <h3>{{title}}</h3>
                        <p>{{custom_excerpt}}</p>
                    </div>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </section>

        {{!-- Partnership Marquee (Even if placeholders, looks premium) --}}
        <section class="partnership-marquee-section reveal reveal-left">
            <h4 class="marquee-title">Trust & Collaboration</h4>
            <div class="marquee-container">
                <div class="marquee-track">
                    {{#get "posts" filter="tag:hash-partner-marquee" limit="100" order="published_at asc"}}
                    {{#foreach posts}}
                        <div class="marquee-item text-logo">{{title}}</div>
                    {{/foreach}}
                    {{!-- Duplicated for smooth loop --}}
                    {{#foreach posts}}
                        <div class="marquee-item text-logo">{{title}}</div>
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </section>

        {{!-- Collaboration Block --}}
        <section class="collaboration-types reveal">
            <div class="collab-grid">
                <div class="collab-info">
                    {{#get "posts" filter="tag:hash-partner-collab-title" limit="1"}}
                    {{#foreach posts}}
                        <h2 class="section-title">{{title}}</h2>
                        <p class="section-text">{{custom_excerpt}}</p>
                    {{else}}
                        <h2 class="section-title">Who can Partner with Us?</h2>
                        <p class="section-text">Join a mission-driven ecosystem dedicated to serving humanity with efficiency and compassion.</p>
                    {{/foreach}}
                    {{/get}}
                </div>
                <div class="collab-list">
                    {{#get "posts" filter="tag:hash-partner-collab" order="published_at asc" limit="10"}}
                    {{#foreach posts}}
                    <div class="collab-item">
                        <div class="collab-num">0{{@number}}</div>
                        <div class="collab-body">
                            <strong>{{title}}</strong>
                            <p>{{custom_excerpt}}</p>
                        </div>
                    </div>
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </section>

    </div>

    {{!-- High-End CTA Section --}}
    <section class="premium-cta-block reveal">
        <div class="container text-center">
            {{#get "posts" filter="tag:hash-partner-cta" limit="1"}}
            {{#foreach posts}}
            <div class="cta-glass-card">
                <h2>{{title}}</h2>
                <p>{{custom_excerpt}}</p>
                <div class="cta-actions">
                    <a href="{{#if canonical_url}}{{canonical_url}}{{else}}mailto:foundationdalailama@gmail.com{{/if}}" class="btn-premium-gold">
                        {{#if primary_tag}}{{primary_tag.name}}{{else}}Contact Leadership{{/if}}
                    </a>
                </div>
            </div>
            {{/foreach}}
            {{else}}
            <div class="cta-glass-card">
                <h2>Ready to Start a Collaboration?</h2>
                <p>Reach out to our leadership team to discuss a strategic partnership for sustainable development.</p>
                <div class="cta-actions">
                    <a href="mailto:foundationdalailama@gmail.com" class="btn-premium-gold">Contact Leadership</a>
                </div>
            </div>
            {{/get}}
        </div>
    </section>

    {{!-- Original Page Content (for reference/editor content) --}}
    <section class="original-content-section reveal">
        <div class="container post-content-body">
            {{content}}
        </div>
    </section>

</article>
{{/post}}
