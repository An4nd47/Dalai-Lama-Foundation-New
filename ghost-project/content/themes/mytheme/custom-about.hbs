{{!< default}}

{{#post}}
<article class="about-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section --}}
    <header class="about-hero" style="background-image: url('{{#if feature_image}}{{img_url feature_image}}{{else}}{{asset "images/about-hero.jpg"}}{{/if}}');">
        <div class="about-hero-overlay"></div>
        <div class="container about-hero-content reveal">
            <span class="hero-label">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Compassion in Action{{/if}}</span>
            <h1 class="about-title">{{title}}</h1>
            <p class="about-subtitle">{{excerpt}}</p>
        </div>
        
        <div class="section-divider">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" preserveAspectRatio="none">
                <path fill="#ffffff" fill-opacity="1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
            </svg>
        </div>
    </header>

    <div class="container about-container">
        {{!-- Founder Section --}}
        <section class="founder-section reveal">
            {{#get "pages" slug="founder-profile" limit="1"}}
                {{#foreach pages}}
                <div class="founder-grid">
                    <div class="founder-image-wrap">
                        <div class="portrait-glow"></div>
                        <img src="{{#if feature_image}}{{img_url feature_image}}{{else}}{{asset "images/dalai-lama-portrait.png"}}{{/if}}" alt="{{title}}" class="floating-portrait">
                        <div class="portrait-label">{{title}}</div>
                    </div>
                    <div class="founder-text-wrap">
                        <h2 class="section-title">Our Inspiration</h2>
                        <div class="section-text">
                            {{content}}
                        </div>
                        {{#if custom_excerpt}}
                        <blockquote class="spiritual-quote">
                            "{{custom_excerpt}}"
                        </blockquote>
                        {{/if}}
                    </div>
                </div>
                {{/foreach}}
            {{/get}}
        </section>

        {{!-- Mission & Vision Grid --}}
        <section class="mission-vision-section reveal">
            <div class="mission-grid">
                {{#get "posts" filter="tag:hash-mission-vision" order="published_at asc" limit="2"}}
                    {{#foreach posts}}
                    <div class="mission-card-premium">
                        {{#if custom_excerpt}}
                        <div class="card-icon">
                            {{{custom_excerpt}}}
                        </div>
                        {{/if}}
                        <h3>{{title}}</h3>
                        <p>{{excerpt}}</p>
                    </div>
                    {{/foreach}}
                {{/get}}
            </div>
        </section>

        {{!-- Original Page Content --}}
        <section class="original-content-section reveal">
            <div class="post-content-body">
                {{content}}
            </div>
        </section>
    </div>

</article>
{{/post}}
