{{!< default}}

{{#post}}
<article class="page-full {{post_class}}">
    {{#match @page.show_title_and_feature_image}}
    <header class="page-full-header">
        <div class="container">
            <h1 class="page-full-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="page-full-excerpt">{{custom_excerpt}}</p>
            {{/if}}
        </div>
    </header>

    {{#if feature_image}}
        <figure class="page-full-image">
            <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" />
        </figure>
    {{/if}}
    {{/match}}

    <section class="page-full-content">
        <div class="container post-content-body">
            {{content}}
        </div>
    </section>
</article>
{{/post}}
