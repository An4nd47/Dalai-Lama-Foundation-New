{{!< default}}

{{#post}}
<article class="about-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section --}}
    <header class="about-hero" style="background-image: url('{{feature_image}}');">
        <div class="about-hero-overlay"></div>
        <div class="container about-hero-content reveal">
            {{#if primary_tag}}<span class="hero-label">{{primary_tag.name}}</span>{{/if}}
            <h1 class="about-title">{{title}}</h1>
            <p class="about-subtitle">{{custom_excerpt}}</p>
        </div>
        
        <div class="section-divider">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" preserveAspectRatio="none">
                <path fill="#ffffff" fill-opacity="1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
            </svg>
        </div>
    </header>

    <div class="container about-container">
        {{!-- Founder Section --}}
        {{#get "posts" filter="tag:hash-about-founder" limit="1"}}
        {{#foreach posts}}
        <section class="founder-section reveal">
            <div class="founder-grid">
                <div class="founder-image-wrap">
                    <div class="portrait-glow"></div>
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}" class="floating-portrait">
                    {{/if}}
                    <div class="portrait-label">{{title}}</div>
                </div>
                <div class="founder-text-wrap">
                    <h2 class="section-title">{{title}}</h2>
                    <p class="section-text">
                        {{custom_excerpt}}
                    </p>
                    <blockquote class="spiritual-quote">
                        {{content}}
                    </blockquote>
                </div>
            </div>
        </section>
        {{/foreach}}
        {{/get}}

        {{!-- Mission & Vision Grid --}}
        <section class="mission-vision-section reveal">
            <div class="mission-grid">
                {{#get "posts" filter="tag:hash-about-mission" order="published_at asc" limit="2"}}
                {{#foreach posts}}
                <div class="mission-card-premium">
                    <div class="card-icon">
                        {{#if feature_image}}
                            <img src="{{feature_image}}" alt="{{title}}" style="width: 32px; height: 32px; object-fit: contain; filter: invert(1) brightness(2);">
                        {{else}}
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v12M6 12h12"></path></svg>
                        {{/if}}
                    </div>
                    <h3>{{title}}</h3>
                    <p>{{custom_excerpt}}</p>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </section>

        {{!-- Original Page Content --}}
        <section class="original-content-section reveal">
            <div class="post-content-body">
                {{content}}
            </div>
        </section>
    </div>

</article>
{{/post}}
