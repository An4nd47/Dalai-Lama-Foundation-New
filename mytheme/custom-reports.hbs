{{!< default}}

{{#post}}
<article class="reports-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section — Formal & Authoritative --}}
    <header class="report-hero" {{#if feature_image}}style="background-image: url('{{feature_image}}'); background-size: cover; background-position: center;"{{/if}}>
        <div class="container report-hero-content reveal">
            {{#if primary_tag}}<span class="report-label">{{primary_tag.name}}</span>{{else}}<span class="report-label">Transparency & Accountability</span>{{/if}}
            <h1 class="report-title">{{title}}</h1>
            <p class="report-subtitle">{{custom_excerpt}}</p>
        </div>
    </header>

    <div class="container report-container">
        
        {{!-- Featured Latest Report --}}
        <section class="latest-report-section reveal">
            {{#get "posts" filter="tag:hash-report-latest-marker" limit="1"}}
            {{#foreach posts}}
            <div class="year-marker">{{title}}</div>
            {{/foreach}}
            {{else}}
            <div class="year-marker">Latest Report</div>
            {{/get}}

            {{#get "posts" filter="tag:hash-report-latest" order="published_at asc" limit="5"}}
            {{#foreach posts}}
            <div class="report-card-premium featured-report">
                <div class="report-icon-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <div class="report-info">
                    <h3>{{title}}</h3>
                    <p>{{custom_excerpt}}</p>
                    <div class="report-highlights-mini gh-content">
                        {{content}}
                    </div>
                </div>
                <div class="report-action">
                    <a href="{{canonical_url}}" class="btn-download-formal">Download Report</a>
                </div>
            </div>
            {{/foreach}}
            {{/get}}
            
            {{#get "posts" filter="tag:hash-report-latest-highlights" limit="1"}}
            {{#foreach posts}}
            <div class="year-highlights reveal">
                <h4>{{title}}</h4>
                <div class="formal-highlights gh-content">
                    {{content}}
                </div>
            </div>
            {{/foreach}}
            {{/get}}
        </section>

        {{!-- Historical Reports Archive --}}
        <section class="historical-reports-section reveal">
            {{#get "posts" filter="tag:hash-report-archive-marker" limit="1"}}
            {{#foreach posts}}
            <div class="year-marker">{{title}}</div>
            {{/foreach}}
            {{else}}
            <div class="year-marker">Archive</div>
            {{/get}}

            {{#get "posts" filter="tag:hash-report-archive" order="published_at asc" limit="10"}}
            {{#foreach posts}}
            <div class="report-card-premium">
                <div class="report-icon-box small">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <div class="report-info">
                    <h3>{{title}}</h3>
                    <p>{{custom_excerpt}}</p>
                    <div class="report-highlights-mini gh-content">
                        {{content}}
                    </div>
                </div>
                <div class="report-action">
                    <a href="{{canonical_url}}" class="btn-download-outline">Download Report</a>
                </div>
            </div>
            {{/foreach}}
            {{/get}}

            {{#get "posts" filter="tag:hash-report-archive-highlights" limit="1"}}
            {{#foreach posts}}
            <div class="year-highlights reveal gh-content">
                <h4>{{title}}</h4>
                <div class="formal-highlights small gh-content">
                    {{content}}
                </div>
            </div>
            {{/foreach}}
            {{/get}}
        </section>

        {{!-- Original Page Content (for reference/hidden) --}}
        <section class="original-content-section reveal">
            <div class="container post-content-body">
                {{content}}
            </div>
        </section>
    </div>

</article>
{{/post}}
