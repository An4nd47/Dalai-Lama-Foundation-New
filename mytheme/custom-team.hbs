{{!< default}}

{{#post}}
<article class="team-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section --}}
    <div class="team-hero" {{#if feature_image}}style="background-image: url('{{feature_image}}'); background-size: cover; background-position: center;"{{/if}}>
        <div class="container team-hero-content reveal">
            {{#if primary_tag}}<span class="hero-label-gold">{{primary_tag.name}}</span>{{/if}}
            <h1 class="team-title">{{title}}</h1>
            <p class="team-subtitle">{{custom_excerpt}}</p>
        </div>
    </div>

    <div class="container team-container">
        
        {{!-- Leadership Spotlight --}}
        <section class="leadership-spotlight reveal">
            {{#get "posts" filter="tag:hash-team-leader" limit="1"}}
            {{#foreach posts}}
            <div class="spotlight-card">
                <div class="leader-image">
                    {{#if feature_image}}<img src="{{feature_image}}" alt="{{title}}" class="leader-img-glow">{{/if}}
                </div>
                <div class="leader-bio">
                    <div class="bio-label">{{#if primary_tag}}{{primary_tag.name}}{{else}}Founder & Leadership{{/if}}</div>
                    <h2>{{title}}</h2>
                    <p class="bio-short">{{custom_excerpt}}</p>
                    <div class="bio-extended gh-content">
                        {{content}}
                    </div>
                </div>
            </div>
            {{/foreach}}
            {{/get}}
        </section>

        {{!-- Team Structure Grid --}}
        <section class="team-grid-section reveal">
            {{#get "posts" filter="tag:hash-team-structure-title" limit="1"}}
            {{#foreach posts}}
            <h2 class="section-title text-center">{{title}}</h2>
            {{/foreach}}
            {{else}}
            <h2 class="section-title text-center">Our Core Structure</h2>
            {{/get}}
            
            <div class="team-structure-grid">
                {{#get "posts" filter="tag:hash-team-member" order="published_at asc" limit="10"}}
                {{#foreach posts}}
                <div class="team-member-card">
                    <div class="member-icon">
                        {{#if feature_image}}<img src="{{feature_image}}" alt="{{title}}" style="width:32px; object-fit: contain;">{{else}}
                            {{#has number="1"}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>{{/has}}
                            {{#has number="2"}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>{{/has}}
                            {{#has number="3"}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>{{/has}}
                            {{^has number="1,2,3"}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon></svg>{{/has}}
                        {{/if}}
                    </div>
                    <h4>{{title}}</h4>
                    <p>{{custom_excerpt}}</p>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </section>

        {{!-- Original Page Content --}}
        <section class="original-content-section reveal">
            <div class="post-content-body">
                {{content}}
            </div>
        </section>
    </div>

</article>
{{/post}}
