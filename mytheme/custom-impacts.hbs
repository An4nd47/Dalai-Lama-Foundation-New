{{!< default}}

{{#post}}
<article class="impacts-page-wrapper {{post_class}}">
    
    {{!-- Premium Hero Section --}}
    <header class="impact-hero" style="background-image: url('{{feature_image}}');">
        <div class="impact-hero-overlay"></div>
        <div class="container impact-hero-content reveal">
            {{#if primary_tag}}<span class="hero-label">{{primary_tag.name}}</span>{{/if}}
            <h1 class="impact-title">{{title}}</h1>
            <p class="impact-subtitle">{{custom_excerpt}}</p>
        </div>
        
        <div class="section-divider">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" preserveAspectRatio="none">
                <path fill="#ffffff" fill-opacity="1" d="M0,160L48,176C96,192,192,224,288,213.3C384,203,480,149,576,149.3C672,149,768,203,864,213.3C960,224,1056,192,1152,170.7C1248,149,1344,139,1392,133.3L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
            </svg>
        </div>
    </header>

    <div class="container impact-container">
        
        {{!-- Stats Section Upgrade --}}
        <section class="stats-premium-grid reveal">
            {{#get "posts" filter="tag:hash-impact-stat" order="published_at asc" limit="4"}}
            {{#foreach posts}}
            <div class="stat-card-premium">
                <div class="stat-inner">
                    <span class="stat-number">{{title}}</span>
                    <span class="stat-desc">{{custom_excerpt}}</span>
                </div>
            </div>
            {{/foreach}}
            {{/get}}
        </section>

        {{!-- Beneficiaries Masonry Highlights --}}
        <section class="beneficiaries-premium reveal reveal-left">
            <div class="beneficiary-grid">
                <div class="beneficiary-image-large">
                    {{#get "posts" filter="tag:hash-impact-beneficiary-image" limit="1"}}
                    {{#foreach posts}}
                        {{#if feature_image}}<img src="{{feature_image}}" alt="{{title}}" class="premium-thumb">{{/if}}
                        <div class="thumb-overlay">
                            <h4>{{title}}</h4>
                            <p>{{custom_excerpt}}</p>
                        </div>
                    {{/foreach}}
                    {{/get}}
                </div>
                <div class="beneficiary-list-wrap">
                    {{#get "posts" filter="tag:hash-impact-beneficiary-title" limit="1"}}
                    {{#foreach posts}}
                        <h2 class="section-title">{{title}}</h2>
                    {{/foreach}}
                    {{else}}
                        <h2 class="section-title">Our Beneficiaries</h2>
                    {{/get}}
                    
                    <ul class="premium-check-list">
                        {{#get "posts" filter="tag:hash-impact-beneficiary" order="published_at asc" limit="5"}}
                        {{#foreach posts}}
                        <li>
                            <strong>{{title}}</strong>
                            <span>{{custom_excerpt}}</span>
                        </li>
                        {{/foreach}}
                        {{/get}}
                    </ul>
                </div>
            </div>
        </section>

        {{!-- Original Page Content --}}
        <section class="original-content-section reveal">
            <div class="post-content-body">
                {{content}}
            </div>
        </section>
    </div>

</article>
{{/post}}
