<section class="partner-logos-section">
    <div class="container">
        {{#get "tags" filter="slug:partner-logo" limit="6" include="feature_image"}}
        <div class="partner-marquee-track">
            {{!-- First set of logos --}}
            {{#foreach tags}}
                <div class="partner-logo">
                    <img src="{{img_url feature_image}}" alt="{{name}}">
                </div>
            {{/foreach}}
            {{!-- Duplicate set for seamless infinite scroll --}}
            {{#foreach tags}}
                <div class="partner-logo">
                    <img src="{{img_url feature_image}}" alt="{{name}}">
                </div>
            {{/foreach}}
        </div>
        {{/get}}
    </div>
</section>
